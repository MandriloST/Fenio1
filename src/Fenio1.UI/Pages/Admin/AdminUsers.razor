@* ======================== USERS ======================== *@
@page "/admin/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject Fenio1.UI.Services.ApiService Api

<PageTitle>Korisnici – Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">👥 Korisnici</h4>
    <button class="btn btn-danger btn-sm" @onclick="() => _showCreate = !_showCreate">+ Novi korisnik</button>
</div>

@if (_showCreate)
{
    <div class="card fenio-card mb-4">
        <div class="card-header fw-bold">Novi korisnik</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Username</label>
                    <input class="form-control fenio-input" @bind="_newUser.Username" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control fenio-input" @bind="_newUser.Email" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Lozinka</label>
                    <input type="password" class="form-control fenio-input" @bind="_newUser.Password" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Uloga</label>
                    <select class="form-select fenio-select" @bind="_newUser.Role">
                        <option value="User">User</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <button class="btn btn-danger" @onclick="CreateUserAsync">Spremi</button>
                <button class="btn btn-outline-secondary" @onclick="() => _showCreate = false">Odustani</button>
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <div class="text-center py-4"><div class="spinner-border text-danger"></div></div>
}
else
{
    <div class="card fenio-card">
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr><th>Username</th><th>Email</th><th>Uloga</th><th>Aktivan</th><th>Kreiran</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var u in _users)
                    {
                        <tr>
                            <td class="fw-bold">@u.Username</td>
                            <td>@u.Email</td>
                            <td><span class="badge @(u.Role == "Admin" ? "bg-danger" : "bg-secondary")">@u.Role</span></td>
                            <td>@(u.IsActive ? "✅" : "❌")</td>
                            <td>@u.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td class="text-end">
                                <button class="btn btn-outline-danger btn-sm"
                                        @onclick="() => DeleteUserAsync(u.Id)">🗑</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<Models.UserDto> _users = new();
    private Models.CreateUserRequest _newUser = new();
    private bool _loading = true, _showCreate;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _users = await Api.GetUsersAsync();
        _loading = false;
    }

    private async Task CreateUserAsync()
    {
        var result = await Api.CreateUserAsync(_newUser);
        if (result != null) { _showCreate = false; _newUser = new(); await LoadAsync(); }
    }

    private async Task DeleteUserAsync(int id)
    {
        if (await Api.DeleteUserAsync(id)) await LoadAsync();
    }
}
