@page "/admin/races/{RaceId:int}/results"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject Fenio1.UI.Services.ApiService Api
@inject NavigationManager Nav

<PageTitle>Unos rezultata – Fenio1 Admin</PageTitle>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-danger"></div></div>
}
else if (_race == null)
{
    <div class="alert alert-danger">Utrka nije pronađena.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="fw-bold mb-0">⚙️ Unos rezultata</h4>
            <small class="text-muted">@_race.Name · Runda @_race.RoundNumber</small>
        </div>
        <a href="/admin/races" class="btn btn-outline-secondary btn-sm">← Natrag</a>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }
    @if (_saved)
    {
        <div class="alert alert-success">✅ Rezultati uneseni! Bodovi su automatski izračunati.</div>
    }

    <!-- UTRKA - Top 10 -->
    <div class="card fenio-card mb-3">
        <div class="card-header fw-bold">🏎️ Poredak u utrci (Top 10)</div>
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0">
                <thead><tr><th style="width:80px">Pozicija</th><th>Vozač</th></tr></thead>
                <tbody>
                    @for (int i = 0; i < 10; i++)
                    {
                        var pos = i + 1;
                        var idx = i;
                        <tr>
                            <td class="fw-bold text-danger align-middle">P@(pos)</td>
                            <td>
                                <select class="form-select form-select-sm fenio-select"
                                        value="@_racePositions[idx]"
                                        @onchange="@(e => _racePositions[idx] = int.Parse(e.Value?.ToString() ?? "0"))">
                                    <option value="0">– Odaberi vozača –</option>
                                    @foreach (var d in _drivers)
                                    {
                                        <option value="@d.Id">@d.DriverNumber · @d.FullName (@d.Code)</option>
                                    }
                                </select>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- KVALIFIKACIJE - Top 3 -->
    <div class="card fenio-card mb-3">
        <div class="card-header fw-bold">⏱️ Poredak u kvalifikacijama (Top 3)</div>
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0">
                <thead><tr><th style="width:80px">Pozicija</th><th>Vozač</th></tr></thead>
                <tbody>
                    @for (int i = 0; i < 3; i++)
                    {
                        var pos = i + 1;
                        var idx = i;
                        <tr>
                            <td class="fw-bold text-warning align-middle">P@(pos)</td>
                            <td>
                                <select class="form-select form-select-sm fenio-select"
                                        value="@_qualPositions[idx]"
                                        @onchange="@(e => _qualPositions[idx] = int.Parse(e.Value?.ToString() ?? "0"))">
                                    <option value="0">– Odaberi vozača –</option>
                                    @foreach (var d in _drivers)
                                    {
                                        <option value="@d.Id">@d.DriverNumber · @d.FullName (@d.Code)</option>
                                    }
                                </select>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- SPRINT - Top 3 (ako postoji) -->
    @if (_race.HasSprint)
    {
        <div class="card fenio-card mb-3">
            <div class="card-header fw-bold">⚡ Poredak u sprint utrci (Top 3)</div>
            <div class="card-body p-0">
                <table class="table table-dark table-hover mb-0">
                    <thead><tr><th style="width:80px">Pozicija</th><th>Vozač</th></tr></thead>
                    <tbody>
                        @for (int i = 0; i < 3; i++)
                        {
                            var pos = i + 1;
                            var idx = i;
                            <tr>
                                <td class="fw-bold text-info align-middle">P@(pos)</td>
                                <td>
                                    <select class="form-select form-select-sm fenio-select"
                                            value="@_sprintPositions[idx]"
                                            @onchange="@(e => _sprintPositions[idx] = int.Parse(e.Value?.ToString() ?? "0"))">
                                        <option value="0">– Odaberi vozača –</option>
                                        @foreach (var d in _drivers)
                                        {
                                            <option value="@d.Id">@d.DriverNumber · @d.FullName (@d.Code)</option>
                                        }
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- POSEBNE KATEGORIJE -->
    <div class="card fenio-card mb-4">
        <div class="card-header fw-bold">🎯 Posebne kategorije</div>
        <div class="card-body">
            <div class="row g-3">
                <!-- DNF - dinamična lista, admin može dodati više vozača -->
                <div class="col-12">
                    <label class="form-label">🚫 Did Not Finish (DNF) – možete dodati više vozača</label>
                    @for (int i = 0; i < _dnfDriverIds.Count; i++)
                    {
                        var idx = i;
                        <div class="d-flex gap-2 mb-2">
                            <select class="form-select fenio-select"
                                    value="@_dnfDriverIds[idx]"
                                    @onchange="@(e => _dnfDriverIds[idx] = int.Parse(e.Value?.ToString() ??" 0"))">
                                <option value="0">– Odaberi vozača –</option>
                                @foreach (var d in _drivers)
                                {
                                    <option value="@d.Id">@d.DriverNumber · @d.FullName (@d.Code)</option>
                                }
                            </select>
                            @if (_dnfDriverIds.Count > 1)
                            {
                                <button class="btn btn-outline-danger btn-sm px-3"
                                        @onclick="() => _dnfDriverIds.RemoveAt(idx)">
                                    ✕
                                </button>
                            }
                        </div>
                    }
                    <button class="btn btn-outline-secondary btn-sm mt-1"
                            @onclick="() => _dnfDriverIds.Add(0)">
                        + Dodaj DNF vozača
                    </button>
                    <div class="form-text text-muted mt-1">
                        Korisnici koji su prognozirali bilo kojeg od ovih vozača osvajaju bodove.
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">⚡ Fastest Lap</label>
                    <select class="form-select fenio-select" @bind="_extras.FastestLapDriverId">
                        <option value="">– Odaberi –</option>
                        @foreach (var d in _drivers)
                        {
                            <option value="@d.Id">@d.FullName (@d.Code)</option>
                        }
                    </select>
                </div>
                @* <div class="col-md-6">
                    <label class="form-label">🏅 Scored Points</label>
                    <select class="form-select fenio-select" @bind="_extras.ScoredPointsDriverId">
                        <option value="">– Odaberi –</option>
                        @foreach (var d in _drivers)
                        {
                            <option value="@d.Id">@d.FullName (@d.Code)</option>
                        }
                    </select>
                </div> *@
                <div class="col-md-6">
                    <label class="form-label">🔧 Fastest Pit Stop</label>
                    <select class="form-select fenio-select" @bind="_extras.FastestPitStopDriverId">
                        <option value="">– Odaberi –</option>
                        @foreach (var d in _drivers)
                        {
                            <option value="@d.Id">@d.FullName (@d.Code)</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">⭐ Driver of the Day</label>
                    <select class="form-select fenio-select" @bind="_extras.DriverOfTheDayId">
                        <option value="">– Odaberi –</option>
                        @foreach (var d in _drivers)
                        {
                            <option value="@d.Id">@d.FullName (@d.Code)</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">🚗 Broj Safety Car izlazaka</label>
                    <input type="number" class="form-control fenio-input" min="0" max="10"
                           @bind="_extras.SafetyCarCount" />
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-end">
        <a href="/admin/races" class="btn btn-outline-secondary">Odustani</a>
        <button class="btn btn-danger fw-bold px-4" @onclick="SubmitAsync" disabled="@_saving">
            @if (_saving) { <span class="spinner-border spinner-border-sm me-2"></span> }
            ✅ Unesi rezultate
        </button>
    </div>
}

@code {
    [Parameter] public int RaceId { get; set; }

    private Models.RaceDto? _race;
    private List<Models.DriverSummaryDto> _drivers = new();
    private int[] _racePositions = new int[10];
    private int[] _qualPositions = new int[3];
    private int[] _sprintPositions = new int[3];
    private AdminExtrasForm _extras = new();
    private bool _loading = true, _saving, _saved;
    private string? _error;
    private List<int> _dnfDriverIds = new() { 0 }; // počni s jednim praznim

    protected override async Task OnInitializedAsync()
    {
        _race = await Api.GetRaceAsync(RaceId);
        _drivers = await Api.GetDriversSummaryAsync();

        // Popuni s postojećim rezultatima ako postoje
        var existing = await Api.GetRaceResultsAsync(RaceId);
        if (existing != null)
        {
            foreach (var r in existing.RacePositions.Where(r => r.Position <= 10))
                _racePositions[r.Position - 1] = r.DriverId;
            foreach (var r in existing.QualifyingPositions.Where(r => r.Position <= 3))
                _qualPositions[r.Position - 1] = r.DriverId;
            if (existing.SprintPositions != null)
                foreach (var r in existing.SprintPositions.Where(r => r.Position <= 3))
                    _sprintPositions[r.Position - 1] = r.DriverId;
            if (existing.Extras != null)
            {
                _dnfDriverIds = existing.Extras.DnfDrivers.Select(d => d.Id).ToList();
                if (_dnfDriverIds.Count == 0) _dnfDriverIds.Add(0);
                _extras.FastestLapDriverId = existing.Extras.FastestLapDriver?.Id;
                // _extras.ScoredPointsDriverId = existing.Extras.ScoredPointsDriver?.Id;
                _extras.FastestPitStopDriverId = existing.Extras.FastestPitStopDriver?.Id;
                _extras.DriverOfTheDayId = existing.Extras.DriverOfTheDay?.Id;
                _extras.SafetyCarCount = existing.Extras.SafetyCarCount;
            }
        }
        _loading = false;
    }

    private async Task SubmitAsync()
    {
        _error = null;
        _saved = false;

        if (_racePositions.Any(p => p == 0)) { _error = "Odaberite svih 10 pozicija u utrci."; return; }
        if (_qualPositions.Any(p => p == 0)) { _error = "Odaberite sve 3 pozicije u kvalifikacijama."; return; }
        if (_race?.HasSprint == true && _sprintPositions.Any(p => p == 0)) { _error = "Odaberite sve 3 sprint pozicije."; return; }

        _saving = true;

        var request = new Models.SubmitRaceResultsRequest
        {
            RacePositions = _racePositions.Select((d, i) => new Models.RaceResultEntryDto { Position = i + 1, DriverId = d }).ToList(),
            QualifyingPositions = _qualPositions.Select((d, i) => new Models.RaceResultEntryDto { Position = i + 1, DriverId = d }).ToList(),
            SprintPositions = _race?.HasSprint == true
                ? _sprintPositions.Select((d, i) => new Models.RaceResultEntryDto { Position = i + 1, DriverId = d }).ToList()
                : null,
            Extras = new Models.AdminRaceExtrasDto
            {
                DnfDriverIds = _dnfDriverIds.Where(id => id > 0).Distinct().ToList(),
                FastestLapDriverId = _extras.FastestLapDriverId,
                // ScoredPointsDriverId = _extras.ScoredPointsDriverId,
                FastestPitStopDriverId = _extras.FastestPitStopDriverId,
                DriverOfTheDayId = _extras.DriverOfTheDayId,
                SafetyCarCount = _extras.SafetyCarCount
            }
        };

        var success = await Api.SubmitRaceResultsAsync(RaceId, request);
        _saved = success;
        if (!success) _error = "Greška pri unosu rezultata.";
        _saving = false;
    }

    private class AdminExtrasForm
    {
        // public int? DnfDriverId { get; set; }
        public int? FastestLapDriverId { get; set; }
        // public int? ScoredPointsDriverId { get; set; }
        public int? FastestPitStopDriverId { get; set; }
        public int? DriverOfTheDayId { get; set; }
        public int SafetyCarCount { get; set; }
    }
}
